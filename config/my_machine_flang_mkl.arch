CXX=clang++
FC=flang

# For flang version 19, option "-mmlir -allow-assumed-rank" is needed
# For flang version 22, it's not requested anymore
FCFLAGS=-cpp  -O2
CPPFLAGS= -DHAVE_MKL


LAPACK=  -L${MKLROOT}/lib/intel64 -Wl,--no-as-needed -lmkl_gf_lp64 -lmkl_sequential -lmkl_core -lpthread -lm -ldl

LIBCINT_ROOT=${HOME}/opt/libcint-6.1.2/
LIBXC_ROOT=${HOME}/opt/libxc-7.0.0/

LDFLAGS=-lquadmath

