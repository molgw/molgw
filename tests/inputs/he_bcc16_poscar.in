&molgw
 scf='lda'

 init_hamiltonian='core'
 ecp_basis='DZV_cp2k'
 ecp_auxil_basis='PW'

 grid_quality='low'       ! fake value
 fft_fix_density_integral='yes'

 ecp_elements='He'
 ecp_type='blyp.gth'

 fft_delta_x = 0.25

 npulay_hist=3

 ! Periodicity vectors and atoms read from POSCAR file
 poscar_file='../data_for_tests/POSCAR_He_bcc16'
/
