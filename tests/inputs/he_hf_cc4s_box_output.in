&molgw
 scf ='HF'


 ecp_basis='GTH-cc-pVTZ'
 ecp_auxil_basis='pw'
 ecp_elements='He'
 ecp_type='hf.gth'

 fft_coulomb_hartree  = 'spherical'
 fft_coulomb_exchange = 'spherical'
 a1=  4., 0., 0.      ! angstrom
 a2=  0., 4., 0.      ! angstrom
 a3=  0., 0., 4.      ! angstrom
 fft_delta_x = 0.18   ! bohr

 print_cc4s_files = 'yes'
 cc4s_output = 'molgw_hf_GTH-TZ'
 fft_ecut_postscf = 60.0

 init_hamiltonian='core'
 npulay_hist=3

 natom = 1
/
He  0. 0. 0.
